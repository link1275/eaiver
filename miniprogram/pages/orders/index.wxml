<view class="page-shell">
  <view class="panel order-list-head">
    <view class="eyebrow">我的订单</view>
    <view class="section-title">查看已提交的陪诊服务单</view>
    <view class="muted">这里展示云开发数据库里的订单记录。</view>
    <view class="cloud-tip {{cloudReady ? 'ready' : 'warning'}}">
      {{cloudReady ? '云开发已连接，可实时读取 escort_orders 集合。' : '请先在 app.js 里配置云环境 ID。'}}
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{isLoading}}">
    <view class="muted">订单加载中...</view>
  </view>

  <view class="order-list" wx:elif="{{orders.length}}">
    <view class="panel order-card" wx:for="{{orders}}" wx:key="_id">
      <view class="order-card-head">
        <view class="card-title">{{item.patientName}}</view>
        <view class="chip">{{item.status}}</view>
      </view>
      <view class="muted">{{item.hospitalName}} · {{item.departmentType}}</view>
      <view class="muted">预约状态：{{item.appointmentStatus}}</view>
      <view class="muted">行动能力：{{item.mobilityLevel}}</view>
      <view class="muted">上门接送：{{item.pickupNeededText}}</view>
      <view class="muted">报告/取药协助：{{item.reportNeededText}}</view>
      <view class="muted">备注：{{item.notes}}</view>
      <view class="order-foot">
        <text class="order-id">ID：{{item._id}}</text>
        <text class="order-time">{{item.createdAtText}}</text>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text class="empty-icon">🗂️</text>
    <text class="empty-text">还没有订单记录，先去下单页提交一笔吧。</text>
  </view>
</view>
